{"title":"Research","markdown":{"yaml":{"title":"Research","title-block-banner":true,"format":{"html":{"page-layout":"full"}}},"containsRefs":false,"markdown":"\n\n<div style=\"max-width:1280px; margin:0rem auto 2rem auto; padding:0 0.35rem;\"><div style=\"display:grid; grid-template-columns:72px 1fr 72px; gap:0.7rem; align-items:center; margin-bottom:1rem;\"><button id=\"mini-prev\" type=\"button\" style=\"position:relative; z-index:40; width:54px; height:54px; border-radius:999px; border:1px solid rgba(216,190,138,0.24); background:rgba(14,27,50,0.82); color:#f5efe2; font-size:2rem; cursor:pointer;\">‹</button><div style=\"overflow:visible;\"><div style=\"max-width:980px; margin:0 auto; overflow:visible;\"><div id=\"mini-stage\" style=\"position:relative; height:600px; overflow:hidden; perspective:2400px; border-radius:1.2rem; background:linear-gradient(180deg, rgba(18,34,63,0.44), rgba(10,19,36,0.34)); border:1px solid rgba(216,190,138,0.10); box-shadow:0 18px 36px rgba(0,0,0,0.16);\"><div class=\"mini-card\" data-index=\"0\" style=\"position:absolute; top:43%; left:50%; width:188px; min-height:510px; transform:translate(-50%,-50%) translateX(0) translateZ(0) scale(1) rotateY(0deg); transform-style:preserve-3d; opacity:1; z-index:6; transition:all 0.5s ease; background:transparent; border:none; border-radius:1rem; overflow:visible; padding:0.18rem; box-shadow:none;\"><div class=\"mini-card-title\" style=\"margin-bottom:0.5rem; text-align:center; color:#d8be8a; font-size:1.02rem; font-weight:600; line-height:1.14; text-shadow:0 2px 8px rgba(0,0,0,0.35);\">Angular Momentum Transport in Molecular Clouds</div><img class=\"mini-card-img\" src=\"images/research/mosaico_ALL_CT.png\" alt=\"Angular Momentum Transport in Molecular Clouds\" style=\"display:block; width:100%; height:414px; max-width:100%; margin:0 auto 0.62rem auto; object-fit:contain; background:rgba(255,255,255,0.02); border-radius:0.78rem; padding:0.02rem; box-shadow:0 12px 26px rgba(0,0,0,0.22);\"><button type=\"button\" class=\"topic-btn\" data-topic=\"clouds\" style=\"display:block; width:max-content; min-width:134px; margin:0 auto; padding:0.78rem 1rem; border-radius:999px; border:1px solid rgba(216,190,138,0.34); background:linear-gradient(135deg, rgba(216,190,138,0.97), rgba(232,208,164,0.93)); color:#08111f; font-size:0.96rem; font-weight:600; cursor:pointer; box-shadow:0 8px 16px rgba(0,0,0,0.16);\">Open me!</button></div><div class=\"mini-card\" data-index=\"1\" style=\"position:absolute; top:43%; left:50%; width:160px; min-height:432px; transform:translate(-50%,-50%) translateX(355px) translateZ(-210px) scale(0.84) rotateY(-34deg); transform-style:preserve-3d; opacity:0.6; z-index:4; transition:all 0.5s ease; background:transparent; border:none; border-radius:1rem; overflow:visible; padding:0.16rem; box-shadow:none;\"><div class=\"mini-card-title\" style=\"margin-bottom:0.36rem; text-align:center; color:#d8be8a; font-size:0.82rem; font-weight:600; line-height:1.1; text-shadow:0 2px 8px rgba(0,0,0,0.32);\">Active Torques in Molecular Clouds</div><img class=\"mini-card-img\" src=\"images/research/torques.png\" alt=\"Active Torques in Molecular Clouds\" style=\"display:block; width:100%; height:348px; max-width:100%; margin:0 auto 0.44rem auto; object-fit:contain; background:rgba(255,255,255,0.02); border-radius:0.76rem; padding:0.02rem; box-shadow:0 10px 22px rgba(0,0,0,0.18);\"><button type=\"button\" class=\"topic-btn\" data-topic=\"torques\" style=\"display:block; width:max-content; min-width:114px; margin:0 auto; padding:0.62rem 0.8rem; border-radius:999px; border:1px solid rgba(216,190,138,0.34); background:linear-gradient(135deg, rgba(216,190,138,0.94), rgba(232,208,164,0.90)); color:#08111f; font-size:0.82rem; font-weight:600; cursor:pointer; box-shadow:0 8px 16px rgba(0,0,0,0.14);\">Open me!</button></div><div class=\"mini-card\" data-index=\"2\" style=\"position:absolute; top:43%; left:50%; width:160px; min-height:432px; transform:translate(-50%,-50%) translateX(-355px) translateZ(-210px) scale(0.84) rotateY(34deg); transform-style:preserve-3d; opacity:0.6; z-index:4; transition:all 0.5s ease; background:transparent; border:none; border-radius:1rem; overflow:visible; padding:0.16rem; box-shadow:none;\"><div class=\"mini-card-title\" style=\"margin-bottom:0.36rem; text-align:center; color:#d8be8a; font-size:0.82rem; font-weight:600; line-height:1.1; text-shadow:0 2px 8px rgba(0,0,0,0.32);\">Angular Momentum Transport in Filaments</div><img class=\"mini-card-img\" src=\"images/research/models.png\" alt=\"Angular Momentum Transport in Filaments\" style=\"display:block; width:100%; height:348px; max-width:100%; margin:0 auto 0.44rem auto; object-fit:contain; background:rgba(255,255,255,0.02); border-radius:0.76rem; padding:0.02rem; box-shadow:0 10px 22px rgba(0,0,0,0.18);\"><button type=\"button\" class=\"topic-btn\" data-topic=\"filaments\" style=\"display:block; width:max-content; min-width:114px; margin:0 auto; padding:0.62rem 0.8rem; border-radius:999px; border:1px solid rgba(216,190,138,0.34); background:linear-gradient(135deg, rgba(216,190,138,0.94), rgba(232,208,164,0.90)); color:#08111f; font-size:0.82rem; font-weight:600; cursor:pointer; box-shadow:0 8px 16px rgba(0,0,0,0.14);\">Open me!</button></div><div class=\"mini-card\" data-index=\"3\" style=\"position:absolute; top:43%; left:50%; width:142px; min-height:378px; transform:translate(-50%,-50%) translateX(565px) translateZ(-370px) scale(0.68) rotateY(-42deg); transform-style:preserve-3d; opacity:0.2; z-index:2; pointer-events:none; transition:all 0.5s ease; background:transparent; border:none; border-radius:1rem; overflow:visible; padding:0.12rem; box-shadow:none; filter:blur(0.7px);\"><div class=\"mini-card-title\" style=\"margin-bottom:0.24rem; text-align:center; color:#d8be8a; font-size:0.72rem; font-weight:600; line-height:1.05; text-shadow:0 2px 8px rgba(0,0,0,0.3);\">Synthetic Observations</div><img class=\"mini-card-img\" src=\"images/research/RT_filament.png\" alt=\"Synthetic Observations\" style=\"display:block; width:100%; height:300px; max-width:100%; margin:0 auto 0.3rem auto; object-fit:contain; background:rgba(255,255,255,0.02); border-radius:0.74rem; padding:0.02rem; box-shadow:0 8px 16px rgba(0,0,0,0.14);\"><button type=\"button\" class=\"topic-btn\" data-topic=\"synthetic\" style=\"display:block; width:max-content; min-width:102px; margin:0 auto; padding:0.52rem 0.68rem; border-radius:999px; border:1px solid rgba(216,190,138,0.34); background:linear-gradient(135deg, rgba(216,190,138,0.92), rgba(232,208,164,0.88)); color:#08111f; font-size:0.74rem; font-weight:600; cursor:pointer; box-shadow:0 8px 16px rgba(0,0,0,0.12);\">Open me!</button></div></div></div></div><button id=\"mini-next\" type=\"button\" style=\"position:relative; z-index:40; width:54px; height:54px; border-radius:999px; border:1px solid rgba(216,190,138,0.24); background:rgba(14,27,50,0.82); color:#f5efe2; font-size:2rem; cursor:pointer;\">›</button></div><div id=\"research-panel\" style=\"display:none; background:linear-gradient(180deg, rgba(14,27,50,0.84), rgba(10,19,36,0.88)); border:1px solid rgba(216,190,138,0.12); border-radius:1.1rem; padding:1.55rem 1.45rem; box-shadow:0 12px 28px rgba(0,0,0,0.20);\"><div id=\"research-panel-title\" style=\"margin-bottom:0.9rem; color:#d8be8a; font-size:1.16rem; font-weight:600; text-align:center;\"></div><div id=\"research-panel-text\" style=\"color:#dce5f7; line-height:1.72; margin-bottom:1.1rem;\"></div><button id=\"research-close-bottom\" type=\"button\" style=\"display:block; margin:0 auto; padding:0.7rem 1rem; border-radius:999px; border:1px solid rgba(216,190,138,0.24); background:rgba(255,255,255,0.04); color:#f5efe2; font-size:0.92rem; font-weight:600; cursor:pointer;\">Close</button></div></div>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function () {\n  var prev = document.getElementById(\"mini-prev\");\n  var next = document.getElementById(\"mini-next\");\n  var panel = document.getElementById(\"research-panel\");\n  var panelTitle = document.getElementById(\"research-panel-title\");\n  var panelText = document.getElementById(\"research-panel-text\");\n  var closeBottom = document.getElementById(\"research-close-bottom\");\n  var openTopic = null;\n  var cards = Array.from(document.querySelectorAll(\".mini-card\"));\n  var current = 0;\n\n function makePanelHTML(paragraph, img1, img2, img3) {\n  return '<div style=\"max-width:900px; margin:0 auto 1.2rem auto; text-align:center;\">' +\n    '<p style=\"margin:0; color:#dce5f7; line-height:1.8;\">' + paragraph + '</p>' +\n    '</div>' +\n    '<div style=\"display:flex; align-items:center; gap:1.2rem; margin:1.2rem 0 1.4rem 0; justify-content:flex-start;\">' +\n      '<img src=\"' + img1 + '\" alt=\"figure\" style=\"width:45%; min-width:240px; max-width:420px; border-radius:0.9rem; box-shadow:0 10px 22px rgba(0,0,0,0.20);\">' +\n      '<div style=\"flex:1; color:#dce5f7; line-height:1.75;\">This example highlights how complex structure emerges across scales and how morphology can be used to connect dynamical evolution with observable signatures in a simple visual way.</div>' +\n    '</div>' +\n    '<div style=\"display:flex; align-items:center; gap:1.2rem; margin:1.2rem 0 1.4rem 0; justify-content:flex-start;\">' +\n      '<div style=\"flex:1; color:#dce5f7; line-height:1.75; text-align:right;\">Here I compare different stages or physical interpretations, emphasizing how the same system can be read through kinematics, geometry, and transport processes acting simultaneously.</div>' +\n      '<img src=\"' + img2 + '\" alt=\"figure\" style=\"width:45%; min-width:240px; max-width:420px; border-radius:0.9rem; box-shadow:0 10px 22px rgba(0,0,0,0.20);\">' +\n    '</div>' +\n    '<div style=\"display:flex; align-items:center; gap:1.2rem; margin:1.2rem 0 0.5rem 0; justify-content:flex-start;\">' +\n      '<img src=\"' + img3 + '\" alt=\"figure\" style=\"width:45%; min-width:240px; max-width:420px; border-radius:0.9rem; box-shadow:0 10px 22px rgba(0,0,0,0.20);\">' +\n      '<div style=\"flex:1; color:#dce5f7; line-height:1.75;\">This final example can be used to point out the broader interpretation of the results, linking numerical experiments, structural evolution, and potential comparison with observational data.</div>' +\n    '</div>';\n}\n\nvar content = {\n  clouds: {\n    title: \"Angular Momentum Transport in Molecular Clouds\",\n    text: makePanelHTML(\n      \"This section introduces the broad question of how angular momentum is acquired, redistributed, and transported during cloud evolution and collapse, with attention to gravity, turbulence, and magnetic structure.\",\n      \"images/research/j_R_S3e1.png\",\n      \"images/research/c2083_visual.png\",\n      \"images/research/am_evolution_separ_3e3.png\"\n    )\n  },\n  torques: {\n    title: \"Active Torques in Molecular Clouds\",\n    text: makePanelHTML(\n      \"This section focuses on the torques that can act inside molecular-cloud environments and on how their relative contribution may vary with geometry, environment, and evolutionary state.\",\n      \"images/research/jR_HDG_ct20_14_15_16Myr.jpeg\",\n      \"images/research/torque_equation.png\",\n      \"images/research/torques_hist_MHDG_ff3.jpg\"\n    )\n  },\n  filaments: {\n    title: \"Angular Momentum Transport in Filaments\",\n    text: makePanelHTML(\n      \"This section explores the possibility that filamentary flows do more than feed mass: they may also channel, redirect, and reorganize angular momentum toward embedded collapse centers.\",\n      \"images/research/heat_cos_3Dangles-2.png\",\n      \"images/research/heat_cos_3Dangles_vel_full_only05.png\",\n      \"images/research/f_N.jpeg\"\n    )\n  },\n  synthetic: {\n    title: \"Synthetic Observations\",\n    text: makePanelHTML(\n      \"This section shows how synthetic observations can bridge the gap between simulations and observable diagnostics, helping interpret structure, emission, and kinematics in a consistent way.\",\n      \"images/research/Filament_1.png\",\n      \"images/research/profile_.png\",\n      \"images/research/RTlines.png\"\n    )\n  }\n};\n\n  function resetButtons() {\n    document.querySelectorAll(\".topic-btn\").forEach(function (btn) {\n      btn.innerHTML = \"Open me!\";\n    });\n  }\n\n  function closePanel() {\n    panel.style.display = \"none\";\n    panelTitle.innerHTML = \"\";\n    panelText.innerHTML = \"\";\n    openTopic = null;\n    resetButtons();\n  }\n\n  function openPanel(topic, button) {\n    if (content[topic]) {\n      panel.style.display = \"block\";\n      panelTitle.innerHTML = content[topic].title;\n      panelText.innerHTML = content[topic].text;\n      openTopic = topic;\n      resetButtons();\n      if (button) button.innerHTML = \"Close\";\n      setTimeout(function () {\n        var y = panel.getBoundingClientRect().top + window.pageYOffset - 70;\n        window.scrollTo({ top: y, behavior: \"smooth\" });\n      }, 80);\n    }\n  }\n\n  function positionFor(offset, total) {\n    var half = Math.floor(total / 2);\n    var signed = offset;\n    if (signed > half) signed = signed - total;\n    return signed;\n  }\n\n  function renderCards() {\n    var total = cards.length;\n    cards.forEach(function (card, i) {\n      var img = card.querySelector(\".mini-card-img\");\n      var title = card.querySelector(\".mini-card-title\");\n      var btn = card.querySelector(\".topic-btn\");\n      var rawOffset = (i - current + total) % total;\n      var pos = positionFor(rawOffset, total);\n\n      card.style.top = \"46%\";\n\n      if (pos === 0) {\n        card.style.width = \"188px\";\n        card.style.minHeight = \"510px\";\n        card.style.transform = \"translate(-50%,-50%) translateX(0) translateZ(0) scale(1) rotateY(0deg)\";\n        card.style.opacity = \"1\";\n        card.style.zIndex = \"6\";\n        card.style.pointerEvents = \"auto\";\n        card.style.filter = \"blur(0)\";\n        card.style.padding = \"0.18rem\";\n        if (img) img.style.height = \"414px\";\n        if (title) title.style.fontSize = \"1.02rem\";\n        if (title) title.style.fontWeight = \"600\";\n        if (btn) btn.style.fontSize = \"0.96rem\";\n        if (btn) btn.style.fontWeight = \"600\";\n        if (btn) btn.style.padding = \"0.78rem 1rem\";\n      } else if (pos === 1) {\n        card.style.width = \"160px\";\n        card.style.minHeight = \"432px\";\n        card.style.transform = \"translate(-50%,-50%) translateX(355px) translateZ(-210px) scale(0.84) rotateY(-34deg)\";\n        card.style.opacity = \"0.6\";\n        card.style.zIndex = \"4\";\n        card.style.pointerEvents = \"auto\";\n        card.style.filter = \"blur(0)\";\n        card.style.padding = \"0.16rem\";\n        if (img) img.style.height = \"348px\";\n        if (title) title.style.fontSize = \"0.84rem\";\n        if (title) title.style.fontWeight = \"600\";\n        if (btn) btn.style.fontSize = \"0.82rem\";\n        if (btn) btn.style.fontWeight = \"600\";\n        if (btn) btn.style.padding = \"0.62rem 0.8rem\";\n      } else if (pos === -1) {\n        card.style.width = \"160px\";\n        card.style.minHeight = \"432px\";\n        card.style.transform = \"translate(-50%,-50%) translateX(-355px) translateZ(-210px) scale(0.84) rotateY(34deg)\";\n        card.style.opacity = \"0.6\";\n        card.style.zIndex = \"4\";\n        card.style.pointerEvents = \"auto\";\n        card.style.filter = \"blur(0)\";\n        card.style.padding = \"0.16rem\";\n        if (img) img.style.height = \"348px\";\n        if (title) title.style.fontSize = \"0.84rem\";\n        if (title) title.style.fontWeight = \"600\";\n        if (btn) btn.style.fontSize = \"0.82rem\";\n        if (btn) btn.style.fontWeight = \"600\";\n        if (btn) btn.style.padding = \"0.62rem 0.8rem\";\n      } else if (pos === 2) {\n        card.style.width = \"142px\";\n        card.style.minHeight = \"378px\";\n        card.style.transform = \"translate(-50%,-50%) translateX(565px) translateZ(-370px) scale(0.68) rotateY(-42deg)\";\n        card.style.opacity = \"0.2\";\n        card.style.zIndex = \"2\";\n        card.style.pointerEvents = \"none\";\n        card.style.filter = \"blur(0.7px)\";\n        card.style.padding = \"0.12rem\";\n        if (img) img.style.height = \"300px\";\n        if (title) title.style.fontSize = \"0.72rem\";\n        if (title) title.style.fontWeight = \"600\";\n        if (btn) btn.style.fontSize = \"0.74rem\";\n        if (btn) btn.style.fontWeight = \"600\";\n        if (btn) btn.style.padding = \"0.52rem 0.68rem\";\n      } else if (pos === -2) {\n        card.style.width = \"142px\";\n        card.style.minHeight = \"378px\";\n        card.style.transform = \"translate(-50%,-50%) translateX(-565px) translateZ(-370px) scale(0.68) rotateY(42deg)\";\n        card.style.opacity = \"0.2\";\n        card.style.zIndex = \"2\";\n        card.style.pointerEvents = \"none\";\n        card.style.filter = \"blur(0.7px)\";\n        card.style.padding = \"0.12rem\";\n        if (img) img.style.height = \"300px\";\n        if (title) title.style.fontSize = \"0.72rem\";\n        if (title) title.style.fontWeight = \"600\";\n        if (btn) btn.style.fontSize = \"0.74rem\";\n        if (btn) btn.style.fontWeight = \"600\";\n        if (btn) btn.style.padding = \"0.52rem 0.68rem\";\n      } else {\n        card.style.width = \"126px\";\n        card.style.minHeight = \"340px\";\n        card.style.transform = \"translate(-50%,-50%) translateX(0) translateZ(-470px) scale(0.56) rotateY(0deg)\";\n        card.style.opacity = \"0\";\n        card.style.zIndex = \"1\";\n        card.style.pointerEvents = \"none\";\n        card.style.filter = \"blur(1px)\";\n        card.style.padding = \"0.08rem\";\n        if (img) img.style.height = \"270px\";\n      }\n    });\n  }\n\n  if (next) {\n    next.onclick = function () {\n      current = (current + 1) % cards.length;\n      renderCards();\n      closePanel();\n    };\n  }\n\n  if (prev) {\n    prev.onclick = function () {\n      current = (current - 1 + cards.length) % cards.length;\n      renderCards();\n      closePanel();\n    };\n  }\n\n  var buttons = document.querySelectorAll(\".topic-btn\");\n  buttons.forEach(function (btn) {\n    btn.addEventListener(\"click\", function () {\n      var topic = this.getAttribute(\"data-topic\");\n      if (openTopic === topic) {\n        closePanel();\n      } else {\n        openPanel(topic, this);\n      }\n    });\n  });\n\n  if (closeBottom) {\n    closeBottom.onclick = function () {\n      closePanel();\n    };\n  }\n\n  renderCards();\n});\n</script>","srcMarkdownNoYaml":"\n\n<div style=\"max-width:1280px; margin:0rem auto 2rem auto; padding:0 0.35rem;\"><div style=\"display:grid; grid-template-columns:72px 1fr 72px; gap:0.7rem; align-items:center; margin-bottom:1rem;\"><button id=\"mini-prev\" type=\"button\" style=\"position:relative; z-index:40; width:54px; height:54px; border-radius:999px; border:1px solid rgba(216,190,138,0.24); background:rgba(14,27,50,0.82); color:#f5efe2; font-size:2rem; cursor:pointer;\">‹</button><div style=\"overflow:visible;\"><div style=\"max-width:980px; margin:0 auto; overflow:visible;\"><div id=\"mini-stage\" style=\"position:relative; height:600px; overflow:hidden; perspective:2400px; border-radius:1.2rem; background:linear-gradient(180deg, rgba(18,34,63,0.44), rgba(10,19,36,0.34)); border:1px solid rgba(216,190,138,0.10); box-shadow:0 18px 36px rgba(0,0,0,0.16);\"><div class=\"mini-card\" data-index=\"0\" style=\"position:absolute; top:43%; left:50%; width:188px; min-height:510px; transform:translate(-50%,-50%) translateX(0) translateZ(0) scale(1) rotateY(0deg); transform-style:preserve-3d; opacity:1; z-index:6; transition:all 0.5s ease; background:transparent; border:none; border-radius:1rem; overflow:visible; padding:0.18rem; box-shadow:none;\"><div class=\"mini-card-title\" sty